---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contacto · Endonautas"
  description="¿Tienes preguntas sobre Endonautas, el sistema o el módulo para profesionales? Escríbenos."
>
  <style>
  .contacto-grid {
    display: grid; grid-template-columns: 1fr 1.1fr;
    gap: 8rem; align-items: start; padding: 10vh 0 12vh;
  }
  .contacto-h {
    font-family: var(--fd); font-size: clamp(2.2rem, 4vw, 3.4rem);
    font-weight: 300; color: #fff; letter-spacing: -.03em;
    line-height: 1.1; margin-bottom: 1.2rem; text-shadow: var(--ts);
  }
  .contacto-sub { color: var(--dim); font-size: .95rem; line-height: 1.75; margin-bottom: 0; max-width: 400px; }
  .c-sep { height: 1px; background: var(--bdr); margin: 2.4rem 0; }
  .c-nota { font-size: .85rem; color: var(--dim); line-height: 1.75; }
  .c-nota strong { color: rgba(255,255,255,.6); }

  /* form */
  .c-form { display: flex; flex-direction: column; gap: 1.4rem; }
  .c-field { display: flex; flex-direction: column; gap: .5rem; }
  .c-label {
    font-size: .72rem; font-weight: 600; letter-spacing: .1em;
    text-transform: uppercase; color: var(--dim);
  }
  .c-label span { color: var(--mut); font-weight: 400; letter-spacing: 0; text-transform: none; font-size: .8rem; }
  .c-input, .c-textarea {
    background: rgba(10,8,20,.55); border: 1px solid var(--bdr);
    border-radius: 10px; color: #fff; font-family: var(--fi);
    font-size: .95rem; padding: .9rem 1.1rem;
    outline: none; transition: border-color .18s;
    width: 100%;
  }
  .c-input::placeholder, .c-textarea::placeholder { color: var(--dim); }
  .c-input:focus, .c-textarea:focus { border-color: rgba(126,204,205,.5); }
  .c-textarea { resize: vertical; min-height: 140px; line-height: 1.6; }
  .c-submit { margin-top: .4rem; }
  .c-feedback {
    display: none; padding: 1rem 1.2rem; border-radius: 10px;
    font-size: .88rem; line-height: 1.6;
  }
  .c-feedback.ok {
    display: block; background: rgba(126,204,205,.08);
    border: 1px solid rgba(126,204,205,.3); color: var(--c);
  }
  .c-feedback.err {
    display: block; background: rgba(212,80,80,.08);
    border: 1px solid rgba(212,80,80,.3); color: #e08080;
  }

  @media (max-width: 860px) {
    .contacto-grid { grid-template-columns: 1fr; gap: 3rem; }
  }
  </style>

  <div class="container">
    <div class="contacto-grid">

      <div class="from-b">
        <p class="lbl" style="color:var(--c);margin-bottom:1rem">Contacto</p>
        <h1 class="contacto-h">Escríbenos</h1>
        <p class="contacto-sub">Para preguntas sobre la app, el módulo para profesionales, el ebook o cualquier otra cosa relacionada con el sistema.</p>

        <div class="c-sep"></div>

        <p class="c-nota">
          <strong>Tiempo de respuesta:</strong> respondemos en 24–48 horas hábiles.<br><br>
          Si tienes una pregunta sobre cómo funciona el sistema antes de registrarte,
          el <a href="/blog/" style="color:var(--c)">blog</a> y la página de
          <a href="/fractones/" style="color:var(--c)">Fractones</a>
          probablemente ya tienen la respuesta.
        </p>
      </div>

      <div class="from-b" data-d="1">
        <form class="c-form" id="cForm" novalidate>
          <div class="c-field">
            <label class="c-label" for="cf-email">Tu email</label>
            <input id="cf-email" name="email" type="email" class="c-input"
              placeholder="tu@correo.com" required autocomplete="email">
          </div>

          <div class="c-field">
            <label class="c-label" for="cf-wa">
              WhatsApp <span>— opcional</span>
            </label>
            <input id="cf-wa" name="whatsapp" type="tel" class="c-input"
              placeholder="+56 9 1234 5678" autocomplete="tel">
          </div>

          <div class="c-field">
            <label class="c-label" for="cf-msg">Mensaje</label>
            <textarea id="cf-msg" name="mensaje" class="c-textarea"
              placeholder="Cuéntanos en qué podemos ayudarte..." required></textarea>
          </div>

          <div id="cf-feedback" class="c-feedback" role="alert"></div>

          <div class="c-submit">
            <button type="submit" class="btn btn-p" id="cf-btn">Enviar mensaje</button>
          </div>
        </form>
      </div>

    </div>
  </div>

  <script is:inline>
  (function () {
    const form = document.getElementById('cForm');
    const btn  = document.getElementById('cf-btn');
    const fb   = document.getElementById('cf-feedback');

    function setFeedback(type, msg) {
      fb.className = 'c-feedback ' + type;
      fb.textContent = msg;
    }

    form.addEventListener('submit', async function (e) {
      e.preventDefault();
      fb.className = 'c-feedback';

      const email   = form.querySelector('#cf-email').value.trim();
      const whatsapp = form.querySelector('#cf-wa').value.trim();
      const mensaje = form.querySelector('#cf-msg').value.trim();

      if (!email || !mensaje) {
        setFeedback('err', 'Por favor completa tu email y el mensaje.');
        return;
      }

      btn.disabled = true;
      btn.textContent = 'Enviando…';

      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, whatsapp, mensaje }),
        });
        const data = await res.json();

        if (data.ok) {
          setFeedback('ok', 'Mensaje enviado — respondemos en 24-48 horas hábiles.');
          form.reset();
        } else {
          setFeedback('err', data.error || 'Ocurrió un error. Intenta de nuevo o escríbenos a hola@endonautas.cl');
        }
      } catch (_) {
        setFeedback('err', 'No se pudo enviar. Escríbenos directamente a hola@endonautas.cl');
      } finally {
        btn.disabled = false;
        btn.textContent = 'Enviar mensaje';
      }
    });
  })();
  </script>
</Layout>
