---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Para profesionales · Endonautas"
  description="Módulo profesional de Endonautas. Fichas de clientes, agenda de sesiones, tests asignables y Terapeuta IA para terapeutas y coaches. Plan Practicante."
  navBadge="Para profesionales"
>
  <a slot="nav" href="/" class="nav-back">← Inicio</a>

  <style>
  /* HERO */
  #hero { min-height: 60vh; display: flex; align-items: center; }
  .hero-inner { max-width: 1100px; margin: 0 auto; width: 100%; padding: 0 7%; }
  .hero-sup { color: var(--vi); margin-bottom: 1.4rem; opacity: 0; animation: fadeUp .7s .1s forwards; }
  .hero-h {
    font-family: var(--fd); font-size: clamp(2.2rem, 4.8vw, 3.8rem);
    font-weight: 700; line-height: 1.1; letter-spacing: -.04em;
    color: #fff; text-shadow: var(--ts); margin-bottom: 1.4rem;
    opacity: 0; animation: fadeUp .8s .3s forwards;
  }
  .hero-h em { color: var(--c); font-style: normal; }
  .hero-p {
    font-size: clamp(1rem, 1.7vw, 1.15rem); color: var(--mut); max-width: 560px;
    line-height: 1.78; margin-bottom: 2.4rem; text-shadow: var(--ts);
    opacity: 0; animation: fadeUp .8s .55s forwards;
  }
  .hero-cta { display: flex; gap: 1rem; flex-wrap: wrap; opacity: 0; animation: fadeUp .8s .8s forwards; }
  /* MÓDULO */
  .modulo-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.2rem; }
  .mod-card {
    border: 1px solid var(--bdr); border-radius: 16px; padding: 2rem;
    background: rgba(10,8,20,.55); backdrop-filter: blur(12px); transition: border-color .22s;
  }
  .mod-card:hover { border-color: rgba(255,255,255,.15); }
  .mod-icon { font-size: 1.4rem; margin-bottom: 1rem; display: block; }
  .mod-title { font-family: var(--fd); font-size: 1rem; font-weight: 600; color: #fff; margin-bottom: .6rem; }
  .mod-desc { font-size: .9rem; color: var(--mut); line-height: 1.7; }
  /* FLUJO */
  .flujo-steps { display: flex; flex-direction: column; gap: 0; max-width: 640px; }
  .flujo-step {
    display: grid; grid-template-columns: 48px 1fr; gap: 1.6rem;
    padding: 2rem 0; border-bottom: 1px solid var(--bdr); align-items: start;
  }
  .flujo-step:last-child { border-bottom: none; }
  .flujo-n {
    width: 48px; height: 48px; border-radius: 50%;
    border: 1px solid rgba(126,204,205,.3); background: rgba(126,204,205,.06);
    display: flex; align-items: center; justify-content: center;
    font-family: var(--fd); font-size: .95rem; font-weight: 700; color: var(--c); flex-shrink: 0;
  }
  .flujo-title { font-family: var(--fd); font-weight: 600; color: #fff; margin-bottom: .4rem; }
  .flujo-desc { font-size: .9rem; color: var(--mut); line-height: 1.68; }
  /* PLAN PRO */
  .plan-pro {
    border: 1px solid rgba(126,204,205,.35); background: rgba(126,204,205,.04);
    border-radius: 16px; padding: 2.4rem; backdrop-filter: blur(12px);
    position: relative; overflow: hidden;
  }
  .plan-pro::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
    background: linear-gradient(90deg, transparent, var(--c), transparent);
  }
  .plan-pro-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: center; }
  .plan-name { font-family: var(--fd); font-size: .7rem; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; color: var(--dim); margin-bottom: 1rem; }
  .plan-tokens { font-family: var(--fd); font-size: 2.8rem; font-weight: 700; color: #fff; letter-spacing: -.04em; line-height: 1; }
  .plan-tokens span { font-size: .82rem; color: var(--dim); font-weight: 400; letter-spacing: 0; }
  .plan-price { font-family: var(--fd); font-size: 1.3rem; font-weight: 600; color: var(--mut); margin-top: .5rem; }
  .plan-ctas { display: flex; flex-direction: column; gap: .75rem; margin-top: 1.6rem; }
  .plan-feats { list-style: none; display: flex; flex-direction: column; gap: .75rem; }
  .plan-feats li { font-size: .9rem; color: var(--mut); line-height: 1.5; display: flex; gap: .55rem; align-items: baseline; }
  .plan-feats li::before { content: '·'; color: var(--c); flex-shrink: 0; }
  .plan-feats li.hi { color: rgba(255,255,255,.88); }
  /* CAPTURA PRACTICANTE */
  .pro-nl-wrap {
    max-width: 580px; margin: 0 auto; text-align: center;
    border: 1px solid rgba(126,204,205,.2); border-radius: 20px;
    padding: 3rem 3.5rem; background: rgba(126,204,205,.03); backdrop-filter: blur(12px);
    position: relative; overflow: hidden;
  }
  .pro-nl-wrap::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px;
    background: linear-gradient(90deg, transparent, rgba(126,204,205,.5), transparent);
  }
  .pro-nl-lbl { font-size: .72rem; letter-spacing: .16em; text-transform: uppercase; color: var(--c); margin-bottom: 1rem; }
  .pro-nl-h {
    font-family: var(--fd); font-size: clamp(1.4rem, 2.8vw, 2rem);
    font-weight: 700; color: #fff; letter-spacing: -.03em; line-height: 1.15;
    margin-bottom: .9rem;
  }
  .pro-nl-sub { font-size: .95rem; color: var(--mut); line-height: 1.72; margin-bottom: 2rem; }
  .pro-nl-form { display: flex; flex-direction: column; gap: .75rem; max-width: 420px; margin: 0 auto; }
  .pro-nl-input-wrap { display: flex; gap: .5rem; }
  .pro-nl-input {
    flex: 1; padding: .85rem 1.1rem; border-radius: 10px;
    border: 1px solid rgba(255,255,255,.12); background: rgba(255,255,255,.05);
    color: #fff; font-size: .95rem; outline: none; transition: border-color .2s;
  }
  .pro-nl-input:focus { border-color: rgba(126,204,205,.5); }
  .pro-nl-btn { white-space: nowrap; font-size: .88rem; padding: .85rem 1.4rem; }
  .pro-nl-note { font-size: .75rem; color: var(--dim); text-align: center; }
  .pro-nl-msg { font-size: .85rem; min-height: 1.2rem; transition: color .2s; }
  .pro-nl-msg.ok { color: var(--c); }
  .pro-nl-msg.err { color: #e87; }
  @media (max-width: 600px) {
    .pro-nl-wrap { padding: 2rem 1.5rem; }
    .pro-nl-input-wrap { flex-direction: column; }
    .pro-nl-btn { width: 100%; }
  }
  /* CIERRE */
  .cierre-quote {
    border: 1px solid rgba(155,142,196,.25); background: rgba(155,142,196,.04);
    border-radius: 16px; padding: 2.4rem 3rem; position: relative;
  }
  .cierre-quote::before {
    content: '◎'; position: absolute; top: -1rem; left: 50%; transform: translateX(-50%);
    font-size: 1.2rem; color: var(--vi); background: #030306; padding: 0 .5rem;
  }
  .cierre-text {
    font-family: var(--fd); font-size: clamp(1.1rem, 2vw, 1.5rem);
    font-weight: 300; color: rgba(255,255,255,.82); line-height: 1.55;
    text-align: center; text-shadow: var(--ts);
  }
  @media (max-width: 768px) {
    .modulo-grid { grid-template-columns: 1fr; }
    .plan-pro-grid { grid-template-columns: 1fr; }
    .hero-cta { flex-direction: column; }
  }
  </style>

  <!-- HERO -->
  <section id="hero" class="s-dark">
    <div class="hero-inner">
      <p class="lbl hero-sup">Módulo profesionales</p>
      <h1 class="hero-h">Las herramientas que usas tú,<br>ahora disponibles para <em>tus pacientes</em></h1>
      <p class="hero-p">La app que usas para tu propio autoconocimiento tiene un modo profesional. Acompaña a tus clientes desde adentro — con las mismas herramientas, pero desde tu rol.</p>
      <p style="font-size:0.88rem;color:rgba(255,255,255,0.38);line-height:1.65;margin-bottom:2.4rem;max-width:480px">Si atiendes 20 pacientes por semana, rehaces contexto clínico en promedio 8 minutos por sesión. Eso es <strong style="color:rgba(255,255,255,0.6)">más de 2 horas por semana</strong> que Endonautas devuelve a la sesión — y al paciente.</p>
      <div class="hero-cta">
        <a href="https://app.endonautas.cl/registro/?plan=practicante" class="btn btn-p">Activar plan Practicante</a>
        <a href="https://app.endonautas.cl/registro/" class="btn btn-o">Primero prueba gratis</a>
      </div>
    </div>
  </section>

  <!-- MÓDULO -->
  <section class="s s-darker">
    <div class="container">
      <h2 class="s-h from-b">Qué incluye el módulo</h2>
      <p class="s-sub from-b" data-d="1">Cuatro herramientas pensadas para el trabajo clínico y de acompañamiento.</p>
      <div class="modulo-grid">
        <div class="mod-card from-b" data-d="1">
          <span class="mod-icon" style="color:var(--c)">◎</span>
          <div class="mod-title">Fichas de clientes</div>
          <p class="mod-desc">Crea un perfil para cada paciente. Accede a su historial de tests, mapas de nacimiento y sesiones — todo en un lugar. El cliente puede registrarse solo o tú creas el perfil temporal.</p>
        </div>
        <div class="mod-card from-b" data-d="2">
          <span class="mod-icon" style="color:var(--am)">·</span>
          <div class="mod-title">Agenda de sesiones</div>
          <p class="mod-desc">Registra fechas, tipo de sesión y notas clínicas privadas. Visualización por semana y mes. Todo asociado al perfil del paciente.</p>
        </div>
        <div class="mod-card from-b" data-d="3">
          <span class="mod-icon" style="color:var(--vi)">✦</span>
          <div class="mod-title">Tests psicométricos asignables</div>
          <p class="mod-desc">Elige de un banco de 35 instrumentos validados y asígnalos a un paciente. Ve los resultados en tiempo real con el insight de IA incluido — antes de la próxima sesión.</p>
        </div>
        <div class="mod-card from-b" data-d="4">
          <span class="mod-icon" style="color:var(--c)">—</span>
          <div class="mod-title">Terapeuta IA</div>
          <p class="mod-desc">Un asistente que analiza el perfil del paciente usando frameworks clínicos: ACT, apego, regulación emocional, somática. No diagnostica — orienta y sugiere técnicas para preparar la sesión.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FLUJO -->
  <section class="s s-dark">
    <div class="container">
      <h2 class="s-h from-b">Cómo funciona</h2>
      <p class="s-sub from-b" data-d="1">Tres pasos para integrar Endonautas a tu práctica.</p>
      <div class="flujo-steps">
        <div class="flujo-step from-b" data-d="1">
          <div class="flujo-n">1</div>
          <div>
            <div class="flujo-title">Crea el perfil de tu paciente</div>
            <p class="flujo-desc">Puedes crear un perfil temporal directamente desde tu cuenta, o invitar al paciente a registrarse. Una vez conectados, tienes acceso a su historial completo.</p>
          </div>
        </div>
        <div class="flujo-step from-b" data-d="2">
          <div class="flujo-n">2</div>
          <div>
            <div class="flujo-title">Asigna tests y lecturas</div>
            <p class="flujo-desc">Elige los instrumentos según lo que quieres evaluar — apego, regulación emocional, estilos de pensamiento, somatización. El paciente los completa desde su cuenta.</p>
          </div>
        </div>
        <div class="flujo-step from-b" data-d="3">
          <div class="flujo-n">3</div>
          <div>
            <div class="flujo-title">Revisa resultados y prepara la sesión</div>
            <p class="flujo-desc">Ve los resultados en tiempo real. Usa el módulo Terapeuta IA para obtener orientación por framework clínico — y llega a la sesión con más contexto y menos suposiciones.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PLAN PRO -->
  <section class="s s-darker">
    <div class="container">
      <h2 class="s-h from-b">Plan Practicante</h2>
      <p class="s-sub from-b" data-d="1">El único plan con acceso al módulo profesional completo.</p>
      <div class="plan-pro from-b" data-d="2">
        <div class="plan-pro-grid">
          <div>
            <p class="plan-name">Practicante</p>
            <div class="plan-tokens">$39 <span>USD / mes</span></div>
            <div class="plan-ctas">
              <a href="https://app.endonautas.cl/registro/?plan=practicante" class="btn btn-p btn-sm">Activar Practicante</a>
              <a href="https://app.endonautas.cl/registro/" class="btn btn-o btn-sm">Probar gratis primero</a>
            </div>
          </div>
          <div>
            <ul class="plan-feats">
              <li class="hi">Módulo terapeuta completo</li>
              <li class="hi">Perfiles de clientes ilimitados</li>
              <li class="hi">Todos los instrumentos desbloqueados</li>
              <li class="hi">Todos los módulos Navegante incluidos</li>
              <li class="hi">35 tests con insight de IA</li>
              <li class="hi">Historial acumulado por paciente</li>
              <li>Agenda de sesiones integrada</li>
              <li>Libro <em>Endonautica</em> incluido</li>
            </ul>
          </div>
        </div>
      </div>
      <p style="font-size:.8rem;color:var(--dim);margin-top:1rem;line-height:1.65" class="from-b" data-d="3">¿No estás listo para el plan Practicante? Puedes explorar la app completa en el <a href="https://app.endonautas.cl/registro/" style="color:var(--c);text-decoration:none">plan gratuito</a> y actualizar cuando quieras.</p>
    </div>
  </section>

  <!-- CAPTURA PRACTICANTE -->
  <section class="s s-darker">
    <div class="container">
      <div class="pro-nl-wrap from-b">
        <p class="pro-nl-lbl">Antes de activar el plan</p>
        <h2 class="pro-nl-h">¿Querés conocer el módulo primero?</h2>
        <p class="pro-nl-sub">Déjanos tu email y te mostramos cómo funciona la ficha de paciente, los tests asignables y el Terapeuta IA — sin tarjeta, sin presión.</p>
        <form class="pro-nl-form" id="proNlForm" novalidate>
          <div class="pro-nl-input-wrap">
            <input type="email" id="proNlEmail" class="pro-nl-input" placeholder="tu@email.com" autocomplete="email" required />
            <button type="submit" class="btn btn-p pro-nl-btn" id="proNlBtn">Mostrarme el módulo</button>
          </div>
          <p class="pro-nl-msg" id="proNlMsg" aria-live="polite"></p>
          <p class="pro-nl-note">Solo 1 email con la demo · Sin compromiso</p>
        </form>
      </div>
    </div>
  </section>

  <script is:inline>
  (function(){
    const form = document.getElementById('proNlForm');
    const emailEl = document.getElementById('proNlEmail');
    const btn = document.getElementById('proNlBtn');
    const msg = document.getElementById('proNlMsg');
    if (!form) return;
    form.addEventListener('submit', async function(e){
      e.preventDefault();
      const email = emailEl.value.trim();
      if (!email) return;
      btn.disabled = true;
      btn.textContent = 'Enviando…';
      msg.textContent = '';
      msg.className = 'pro-nl-msg';
      try {
        const res = await fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, list: 'practicante' })
        });
        const data = await res.json();
        if (data.ok) {
          msg.textContent = 'Listo — revisá tu email pronto.';
          msg.className = 'pro-nl-msg ok';
          emailEl.value = '';
          btn.textContent = '¡Enviado!';
        } else {
          throw new Error(data.error || 'Error');
        }
      } catch(err) {
        msg.textContent = 'Algo salió mal. Intentá de nuevo.';
        msg.className = 'pro-nl-msg err';
        btn.disabled = false;
        btn.textContent = 'Mostrarme el módulo';
      }
    });
  })();
  </script>

  <!-- TALLER 1 TERAPEUTAS -->
  <section class="s s-darker" id="taller-1">
    <div class="container">
      <div class="pro-nl-wrap from-b">
        <p class="pro-nl-lbl">Taller presencial · 1 de agosto</p>
        <h2 class="pro-nl-h">Tu paciente vuelve al mismo patrón el miércoles</h2>
        <p class="pro-nl-sub">Cada paciente que no ve avances entre sesiones está un paso más cerca de dejar la terapia. Taller presencial de 100 min para terapeutas y coaches: cómo dar a tus pacientes una herramienta real para el trabajo entre sesiones. Incluye acceso al Plan Practicante + 1er mes gratis de regalo — es tuyo aunque el taller no te convenza, sin riesgo.</p>
        <form class="pro-nl-form" id="tallerNlForm" novalidate>
          <div class="pro-nl-input-wrap">
            <input type="email" id="tallerNlEmail" class="pro-nl-input" placeholder="tu@email.com" autocomplete="email" required />
            <button type="submit" class="btn btn-p pro-nl-btn" id="tallerNlBtn">Anotarme en la lista de espera</button>
          </div>
          <p class="pro-nl-msg" id="tallerNlMsg" aria-live="polite"></p>
          <p class="pro-nl-note">El lugar se confirma según cuántos se anoten — cupo real y limitado.</p>
        </form>
      </div>
    </div>
  </section>

  <script is:inline>
  (function(){
    const form = document.getElementById('tallerNlForm');
    const emailEl = document.getElementById('tallerNlEmail');
    const btn = document.getElementById('tallerNlBtn');
    const msg = document.getElementById('tallerNlMsg');
    if (!form) return;
    form.addEventListener('submit', async function(e){
      e.preventDefault();
      const email = emailEl.value.trim();
      if (!email) return;
      btn.disabled = true;
      btn.textContent = 'Enviando…';
      msg.textContent = '';
      msg.className = 'pro-nl-msg';
      try {
        const res = await fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, list: 'taller1-terapeutas' })
        });
        const data = await res.json();
        if (data.ok) {
          msg.textContent = 'Listo — te confirmamos lugar y fecha por email.';
          msg.className = 'pro-nl-msg ok';
          emailEl.value = '';
          btn.textContent = '¡Anotado!';
        } else {
          throw new Error(data.error || 'Error');
        }
      } catch(err) {
        msg.textContent = 'Algo salió mal. Intenta de nuevo.';
        msg.className = 'pro-nl-msg err';
        btn.disabled = false;
        btn.textContent = 'Anotarme en la lista de espera';
      }
    });
  })();
  </script>

  <!-- CIERRE -->
  <section class="s s-dark">
    <div class="container">
      <div class="cierre-quote from-b">
        <p class="cierre-text">"No es una herramienta de diagnóstico.<br>Es un espejo que el paciente ya puede ver — y tú puedes leer junto a él."</p>
      </div>
    </div>
  </section>
</Layout>
