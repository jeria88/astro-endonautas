function buildAvatarCard(slug, avatarName, variants) {
  const card = document.createElement('div');
  card.className = 'avatar-card';
  const tabs = variants.map((_, i) =>
    `<button class="vtab${i===0?' active':''}" onclick="switchVTab(this,'${avatarName}',${i})">V${i+1}</button>`
  ).join('');
  const panels = variants.map((v, i) => {
    const slides = v.carousel?.slides || [];
    const slidesHtml = slides.map((s, si) => {
      const total = slides.length;
      const cls = si === 0 ? 'hook' : si === total - 1 ? 'cta' : '';
      return `<div class="slide-copy-row">
        <span class="slide-copy-n">${String(si+1).padStart(2,'0')}</span>
        <span class="slide-copy-txt ${cls}">${esc(s)}</span>
      </div>`;
    }).join('');
    const hookTxt = v.reel ? `${v.reel.hook_a || ''} / ${v.reel.hook_b || ''}` : '';
    const dirOpts = Object.entries(DIRECTOR_SHORT)
      .map(([k, lbl]) => `<button class="dir-btn" data-avatar="${avatarName}" data-vi="${i}" data-dir="${k}"
        onclick="legacySelectDir(this,'${slug}')">${lbl}</button>`).join('');
    return `<div class="variant-panel${i===0?' active':''}" id="vp-${avatarName}-${i}">
      <div>${slidesHtml}</div>
      ${hookTxt ? `<div style="margin-top:0.5rem;padding:0.5rem;background:rgba(255,255,255,0.025);border-radius:7px;font-size:0.78rem;color:var(--muted)">${esc(hookTxt)}</div>` : ''}
      <div class="dir-row">
        <div class="dir-label">Director</div>
        <div class="dir-opts">${dirOpts}</div>
      </div>
      <div class="fmt-row">
        <button class="fmt-btn" data-avatar="${avatarName}" data-vi="${i}" data-type="carousel"
          onclick="legacyFmt(this,'${slug}')">Carrusel</button>
        <button class="fmt-btn" data-avatar="${avatarName}" data-vi="${i}" data-type="reel"
          onclick="legacyFmt(this,'${slug}')">Reel</button>
      </div>
    </div>`;
  }).join('');
  card.innerHTML = `
    <div class="avatar-name">${esc(AVATAR_LABELS[avatarName] || avatarName)}</div>
    <div class="variant-tabs">${tabs}</div>
    ${panels}
  `;
  return card;
}

// ── LEGACY INTERACTIONS ────────────────────────────────────────────────────────

const _legacySels = {};

function legacySelKey(s, a, vi) { return `${s}|${a}:${vi}`; }

function switchVTab(btn, avatarName, idx) {
  const card = btn.closest('.avatar-card');
  card.querySelectorAll('.vtab').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  card.querySelectorAll('.variant-panel').forEach(p => p.classList.remove('active'));
  card.querySelector(`#vp-${avatarName}-${idx}`).classList.add('active');
}

function legacySelectDir(btn, slug) {
  const { avatar, vi, dir } = btn.dataset;
  const key = legacySelKey(slug, avatar, vi);
  if (!_legacySels[key]) _legacySels[key] = { carousel: false, reel: false, director: '' };
  _legacySels[key].director = dir;
  btn.closest('.dir-opts').querySelectorAll('.dir-btn').forEach(b => b.classList.remove('sel-c'));
  btn.classList.add('sel-c');
  const approveBtn = document.getElementById(`approve-btn-${slug}`);
  if (approveBtn) approveBtn.disabled = !Object.values(_legacySels).some(s => s.carousel || s.reel);
}

function legacyFmt(btn, slug) {
  const { avatar, vi, type } = btn.dataset;
  const key = legacySelKey(slug, avatar, vi);
  if (!_legacySels[key]) _legacySels[key] = { carousel: false, reel: false, director: '' };
  _legacySels[key][type] = !_legacySels[key][type];
  if (!_legacySels[key].carousel && !_legacySels[key].reel) delete _legacySels[key];
  btn.className = 'fmt-btn' + (_legacySels[key]?.[type] ? ` on-${type}` : '');
  const approveBtn = document.getElementById(`approve-btn-${slug}`);
  if (approveBtn) approveBtn.disabled = !Object.entries(_legacySels).some(([k,s]) => k.startsWith(slug+'|') && (s.carousel||s.reel));
}

async function approveLegacy(slug) {
  const btn = document.getElementById(`approve-btn-${slug}`);
  const msg = document.getElementById(`approve-msg-${slug}`);
  const approved_selections = Object.entries(_legacySels)
    .filter(([k]) => k.startsWith(slug+'|'))
    .map(([k, { carousel, reel, director }]) => {
      const rest = k.slice(slug.length + 1);
      const ci = rest.indexOf(':');
      return { avatar: rest.slice(0,ci), variant_index: Number(rest.slice(ci+1)), carousel, reel, director: director || null };
    });
  if (!approved_selections.length) return;
  btn.disabled = true; btn.textContent = 'Enviando…';
  try {
    const res  = await fetch('/api/approve-copy', {
      method: 'POST', credentials: 'same-origin',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ slug, approved_selections }),
    });
    const data = await res.json();
    if (data.ok) {
      btn.textContent = `✓ ${data.approved} en cola`;
      if (msg) msg.textContent = 'Se generan en el próximo ciclo (~30 min).';
    } else {
      btn.disabled = false; btn.textContent = 'Aprobar este artículo';
      if (msg) msg.textContent = `Error: ${data.error}`;
    }
  } catch (e) {
    btn.disabled = false; btn.textContent = 'Aprobar este artículo';
    if (msg) msg.textContent = `Error: ${e.message}`;
  }
}

// ── VISUAL APPROVE ─────────────────────────────────────────────────────────────

async function approveVisual(slug, btn) {
  btn.disabled = true; btn.textContent = 'Añadiendo…';
  try {
    const res  = await fetch('/api/approve-visual', {
      method: 'POST', credentials: 'same-origin',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ slug }),
    });
    const data = await res.json();
    if (data.ok) {
      btn.textContent = '✓ En cola';
      _nextQueueSlot++;
      _refreshQueueDates();
    } else {
      btn.disabled = false;
      btn.textContent = 'Añadir a la cola';
      console.error('approve-visual error:', data.error);
    }
  } catch (e) {
    btn.disabled = false;
    btn.textContent = 'Añadir a la cola';
    console.error(e);
  }
}

// ── RETRY GENERATION ───────────────────────────────────────────────────────────

async function retryGeneration(slug, btn) {
  btn.disabled = true; btn.textContent = 'Reintentando…';
  try {
    const res  = await fetch('/api/retry-generation', {
      method: 'POST', credentials: 'same-origin',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ slug }),
    });
    const data = await res.json();
    if (data.ok) {
      btn.textContent = '✓ Enviado al cron';
      btn.closest('.error-block').style.opacity = '0.4';
    } else {
      btn.disabled = false;
      btn.textContent = 'Reintentar generación';
      console.error('retry error:', data.error);
    }
  } catch (e) {
    btn.disabled = false;
    btn.textContent = 'Reintentar generación';
    console.error(e);
  }
}

// ── LIGHTBOX ───────────────────────────────────────────────────────────────────

let lbUrls = [], lbIdx = 0, lbIsVideo = false;

function _lbShow(url, isVideo) {
  const img = document.getElementById('lb-img');
  const vid = document.getElementById('lb-video');
  lbIsVideo = isVideo;
  if (isVideo) {
    img.style.display = 'none';
    vid.style.display = '';
    vid.src = url; vid.play();
  } else {
    vid.style.display = 'none'; vid.pause();
    img.style.display = '';
    img.src = url;
  }
}

function openLb(urls, idx) {
  lbUrls = urls; lbIdx = idx;
  _lbShow(urls[idx], false);
  document.getElementById('lb-counter').textContent = `${idx+1} / ${urls.length}`;
  document.getElementById('lightbox').classList.add('open');
}

function openReel(url) {
  lbUrls = [url]; lbIdx = 0;
  _lbShow(url, true);
  document.getElementById('lb-counter').textContent = 'reel';
  document.getElementById('lightbox').classList.add('open');
}

function closeLb() {
  document.getElementById('lightbox').classList.remove('open');
  const vid = document.getElementById('lb-video');
  vid.pause(); vid.src = '';
}

function lbStep(d) {
  if (lbIsVideo) return;
  lbIdx = (lbIdx + d + lbUrls.length) % lbUrls.length;
  _lbShow(lbUrls[lbIdx], false);
  document.getElementById('lb-counter').textContent = `${lbIdx+1} / ${lbUrls.length}`;
}

document.getElementById('lightbox').addEventListener('click', e => {
  if (e.target === e.currentTarget) closeLb();
});
document.addEventListener('keydown', e => {
  if (!document.getElementById('lightbox').classList.contains('open')) return;
  if (e.key === 'Escape') closeLb();
  if (e.key === 'ArrowLeft') lbStep(-1);
  if (e.key === 'ArrowRight') lbStep(1);
});

// ── SECTION TOGGLE ─────────────────────────────────────────────────────────────

function toggleSec(id) {
  const body   = document.getElementById(id);
  const toggle = document.querySelector(`[data-toggle="${id}"]`);
  const open   = !body.classList.contains('collapsed');
  body.classList.toggle('collapsed', open);
  if (toggle) toggle.classList.toggle('collapsed', open);
}

function buildSection(title, builder, items) {
  const id  = `sec-${Math.random().toString(36).slice(2,8)}`;
  const sec = document.createElement('div');
  sec.innerHTML = `
    <div class="section-h toggleable" onclick="toggleSec('${id}')">
      <span>${title}</span>
      <span class="section-toggle" data-toggle="${id}">▼</span>
    </div>
    <div class="section-body" id="${id}"></div>`;
  const body = sec.querySelector(`#${id}`);
  items.forEach(item => body.appendChild(builder(item)));
  return sec;
}

// ── LOAD ───────────────────────────────────────────────────────────────────────

async function load() {
  const res  = await fetch('/api/list-pending', { credentials: 'same-origin' });
  const data = await res.json();
  document.getElementById('loading').style.display = 'none';

  const ns = data.scored?.length       || 0;
  const nr = data.ready_review?.length || 0;
  const nc = data.copy_pending?.length || 0;
  const ne = data.errors?.length       || 0;
  const parts = [];
  if (nr) parts.push(`${nr} en cola`);
  if (ns) parts.push(`${ns} con finalistas`);
  if (nc) parts.push(`${nc} pendiente${nc>1?'s':''}`);
  if (ne) parts.push(`${ne} con error`);
  const badge = document.getElementById('status-badge');
  if (badge) badge.textContent = parts.join(' · ') || 'sin pendientes';

  const c = document.getElementById('content');

  if (data.ready_review?.length)
    c.appendChild(buildSection(`Cola de publicación — ${nr} artículo${nr>1?'s':''}`, buildOutputBlock, data.ready_review));

  if (data.scored?.length)
    c.appendChild(buildSection('Finalistas IA — elige, edita y aprueba', buildScoredBlock, data.scored));

  if (data.errors?.length)
    c.appendChild(buildSection('Errores de generación — reintentar', buildErrorBlock, data.errors));

  if (data.copy_pending?.length)
    c.appendChild(buildSection(`Copy pendiente (${data.copy_pending.length} artículos)`, buildCopyBlock, data.copy_pending));

  if (!ns && !nr && !nc && !ne) document.getElementById('empty').style.display = '';
}

load().catch(e => {
  document.getElementById('loading').style.display = 'none';
  document.getElementById('empty').style.display = '';
  document.getElementById('empty').textContent = `Error: ${e.message}`;
});
</script>
