---
// Página interna — revisión de output social por Franco.
// Excluida del sitemap. Solo Franco.
---
<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Review — Endonautas</title>
<style is:global>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --bg:          #030306;
  --surface:     #0c0c10;
  --surface-2:   #111116;
  --border:      rgba(255,255,255,0.08);
  --border-hi:   rgba(255,255,255,0.16);
  --text:        #f0e8dc;
  --muted:       rgba(240,232,220,0.42);
  --dim:         rgba(240,232,220,0.2);
  --teal:        #7ecccd;
  --teal-bg:     rgba(126,204,205,0.08);
  --teal-border: rgba(126,204,205,0.28);
  --purple:      #c0a0f0;
  --red:         #e8636a;
  --amber:       #d4a056;
  --green:       #5bd6a0;
}

body {
  background: var(--bg); color: var(--text);
  font-family: 'Inter', system-ui, sans-serif;
  font-size: 13.5px; line-height: 1.5;
  padding: 1.25rem 1.25rem 5rem;
  max-width: 1440px; margin: 0 auto;
}

/* ── PAGE HEADER ── */
.page-header {
  display: flex; align-items: center; gap: 0.875rem;
  margin-bottom: 1.75rem; flex-wrap: wrap;
}
.page-title {
  font-size: 0.82rem; font-weight: 700; letter-spacing: 0.1em;
  text-transform: uppercase; color: var(--teal);
}
.page-badge {
  font-size: 0.58rem; letter-spacing: 0.1em; color: var(--muted);
  border: 1px solid var(--border); padding: 3px 10px; border-radius: 20px;
  text-transform: uppercase;
}

/* ── ARTICLE BLOCK ── */
.article-block { margin-bottom: 2.75rem; padding-bottom: 2.25rem; border-bottom: 1px solid var(--border); }
.article-block:last-child { border-bottom: none; }

.article-title { font-size: 0.96rem; font-weight: 600; margin-bottom: 0.15rem; line-height: 1.35; }
.article-slug  { font-size: 0.58rem; color: var(--dim); letter-spacing: 0.03em; margin-bottom: 1.1rem; }

.section-h {
  font-size: 0.55rem; letter-spacing: 0.22em; text-transform: uppercase; color: var(--dim);
  padding-bottom: 0.7rem; border-bottom: 1px solid var(--border); margin-bottom: 1.5rem;
}
.section-h.toggleable {
  display: flex; align-items: center; justify-content: space-between;
  cursor: pointer; user-select: none;
}
.section-h.toggleable:hover { color: var(--muted); border-color: var(--border-hi); }
.section-toggle { font-size: 0.7rem; transition: transform 0.2s; }
.section-toggle.collapsed { transform: rotate(-90deg); }
.section-body { overflow: hidden; }
.section-body.collapsed { display: none; }

/* ── MEDIA SUBSECTION within article ── */
.media-subsection { margin-bottom: 1.5rem; }
.media-subsection-h {
  font-size: 0.5rem; letter-spacing: 0.18em; text-transform: uppercase;
  color: var(--teal); opacity: 0.7; margin-bottom: 0.6rem;
  display: flex; align-items: center; gap: 0.5rem;
}
.media-subsection-h::after {
  content: ''; flex: 1; height: 1px; background: var(--border);
}

/* ── FINALIST GRID — horizontal filmstrip ── */
.finalist-grid {
  display: flex;
  flex-direction: row;
  gap: 0.875rem;
  margin-bottom: 0.875rem;
  overflow-x: auto;
  padding-bottom: 0.75rem;
  scrollbar-width: thin;
  scrollbar-color: rgba(255,255,255,0.1) transparent;
}
.finalist-grid::-webkit-scrollbar { height: 4px; }
.finalist-grid::-webkit-scrollbar-track { background: transparent; }
.finalist-grid::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 4px; }

/* ── FINALIST CARD ── */
.finalist-card {
  flex: 0 0 260px;
  min-width: 260px;
  border: 1px solid var(--border); border-radius: 11px;
  background: var(--surface); display: flex; flex-direction: column;
  transition: border-color 0.18s ease;
}
.finalist-card.state-approved { border-color: var(--teal-border); background: rgba(126,204,205,0.025); }
.finalist-card.state-skipped  { opacity: 0.3; }

/* Card header */
.card-hd {
  display: flex; align-items: center; gap: 0.65rem;
  padding: 0.8rem 0.9rem 0.65rem;
  border-bottom: 1px solid var(--border);
}
.card-label {
  font-size: 0.7rem; font-weight: 700; color: var(--text);
  flex: 1; min-width: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.card-score {
  font-size: 1.35rem; font-weight: 800; line-height: 1; letter-spacing: -0.04em; flex-shrink: 0;
}
.sc-high { color: var(--teal); }
.sc-mid  { color: var(--amber); }
.sc-low  { color: var(--red); }

.card-dir-select {
  background: var(--surface-2); border: 1px solid var(--border);
  border-radius: 6px; color: var(--muted);
  font-size: 0.6rem; padding: 3px 5px; outline: none; cursor: pointer;
  max-width: 108px; flex-shrink: 0;
}
.card-dir-select:focus { border-color: var(--teal-border); color: var(--text); }
option { background: #111116; }

/* Dim bars */
.dim-row {
  display: flex; gap: 0.25rem; padding: 0.45rem 0.9rem 0.5rem;
  border-bottom: 1px solid var(--border);
}
.dim-item  { flex: 1; display: flex; flex-direction: column; gap: 2px; align-items: center; }
.dim-lbl   { font-size: 0.46rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--dim); }
.dim-track { width: 100%; height: 2px; background: rgba(255,255,255,0.07); border-radius: 2px; }
.dim-fill  { height: 100%; border-radius: 2px; background: var(--teal); opacity: 0.65; }
.dim-val   { font-size: 0.52rem; color: var(--muted); font-variant-numeric: tabular-nums; }

/* Slides */
.slides-section {
  padding: 0.6rem 0.9rem; max-height: 190px; overflow-y: auto;
  border-bottom: 1px solid var(--border);
  scrollbar-width: thin; scrollbar-color: rgba(255,255,255,0.08) transparent;
}
.slide-row { display: flex; gap: 0.45rem; align-items: baseline; padding: 0.28rem 0; }
.slide-row + .slide-row { border-top: 1px solid rgba(255,255,255,0.04); }
.slide-n   { font-size: 0.5rem; color: var(--dim); min-width: 1.3rem; flex-shrink: 0; font-variant-numeric: tabular-nums; }
.slide-txt { font-size: 0.8rem; color: var(--text); line-height: 1.4; }
.slide-txt.is-hook { font-weight: 700; }
.slide-txt.is-cta  { color: var(--teal); font-weight: 600; font-size: 0.74rem; }

/* Reel hooks */
.reel-section {
  padding: 0.5rem 0.9rem; border-bottom: 1px solid var(--border);
  background: rgba(192,160,240,0.03);
}
.reel-row { display: flex; gap: 0.4rem; align-items: baseline; margin-bottom: 0.18rem; }
.reel-lbl { font-size: 0.5rem; color: var(--dim); min-width: 1.1rem; flex-shrink: 0; letter-spacing: 0.05em; }
.reel-txt { font-size: 0.78rem; color: rgba(240,232,220,0.72); line-height: 1.35; }

/* Justification */
.card-justif {
  padding: 0.45rem 0.9rem; font-size: 0.68rem; color: var(--dim);
  font-style: italic; line-height: 1.5; border-bottom: 1px solid var(--border);
}

/* Caption tabs */
.cap-tab-row {
  display: flex; border-bottom: 1px solid var(--border);
}
.cap-tab {
  padding: 6px 11px; font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.06em;
  cursor: pointer; background: transparent; border: none; color: var(--dim);
  border-bottom: 2px solid transparent; margin-bottom: -1px; transition: color 0.14s;
}
.cap-tab:hover { color: var(--muted); }
.cap-tab.active { color: var(--teal); border-bottom-color: var(--teal); }

.cap-panels { padding: 0.6rem 0.9rem; flex: 1; }
.cap-panel  { display: none; }
.cap-panel.active { display: block; }

.cap-textarea {
  width: 100%; resize: none;
  background: rgba(255,255,255,0.03); border: 1px solid var(--border);
  border-radius: 7px; padding: 0.55rem 0.7rem;
  color: rgba(240,232,220,0.82);
  font-family: 'Inter', system-ui, sans-serif; font-size: 0.72rem; line-height: 1.5;
  outline: none; transition: border-color 0.14s;
  scrollbar-width: thin; scrollbar-color: rgba(255,255,255,0.08) transparent;
  min-height: 90px; max-height: 140px; overflow-y: auto;
}
.cap-textarea:focus { border-color: var(--teal-border); }

.cap-char {
  text-align: right; font-size: 0.52rem; color: var(--dim); margin-top: 3px;
  font-variant-numeric: tabular-nums;
}
.cap-char.over { color: var(--red); }
.cap-yt-lbl    { font-size: 0.54rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--dim); margin-bottom: 0.2rem; }
.cap-yt-fields { display: flex; flex-direction: column; gap: 0.5rem; }

/* Card footer */
.card-ft {
  padding: 0.6rem 0.9rem; border-top: 1px solid var(--border);
  background: var(--surface-2); border-radius: 0 0 11px 11px;
  display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap;
}
.fmt-toggle {
  display: flex; align-items: center; gap: 0.3rem;
  font-size: 0.64rem; color: var(--muted); cursor: pointer; user-select: none;
}
.fmt-toggle input[type="checkbox"] { width: 12px; height: 12px; cursor: pointer; accent-color: var(--teal); }
.ft-divider { flex: 1; }

.btn-skip {
  padding: 5px 11px; border-radius: 6px; border: 1px solid var(--border);
  background: transparent; color: var(--dim); font-size: 0.62rem; cursor: pointer;
  transition: color 0.14s, border-color 0.14s; white-space: nowrap;
}
.btn-skip:hover { color: var(--muted); border-color: var(--border-hi); }
.btn-skip.skipped { color: var(--red); border-color: rgba(232,99,106,0.3); }

.btn-approve {
  padding: 5px 13px; border-radius: 6px;
  border: 1px solid var(--teal-border); background: var(--teal-bg);
  color: var(--teal); font-size: 0.62rem; font-weight: 700;
  letter-spacing: 0.04em; cursor: pointer; white-space: nowrap;
  transition: background 0.14s;
}
.btn-approve:hover { background: rgba(126,204,205,0.15); }
.btn-approve.approved { background: var(--teal); color: #020e0e; }

/* Article footer */
.article-ft {
  display: flex; align-items: center; gap: 0.75rem; margin-top: 0.875rem; flex-wrap: wrap;
}
.btn-submit {
  padding: 8px 20px; border-radius: 30px; border: none;
  background: var(--teal); color: #020e0e;
  font-size: 0.68rem; font-weight: 700; letter-spacing: 0.07em; text-transform: uppercase;
  cursor: pointer;
}
.btn-submit:disabled { opacity: 0.22; cursor: not-allowed; }
.btn-submit:hover:not(:disabled) { filter: brightness(1.07); }
.submit-msg { font-size: 0.62rem; color: var(--muted); }

/* ── OUTPUT BLOCK (ready_to_publish) ── */
.media-lbl {
  font-size: 0.6rem; color: var(--dim); letter-spacing: 0.12em;
  text-transform: uppercase; margin-bottom: 0.55rem;
}
.carousel-strip {
  display: flex; gap: 0.55rem; overflow-x: auto; padding-bottom: 0.6rem; margin-bottom: 1.1rem;
  scrollbar-width: thin; scrollbar-color: rgba(255,255,255,0.08) transparent;
}
.slide-thumb {
  flex-shrink: 0; width: 148px; height: 148px; border-radius: 9px;
  overflow: hidden; border: 1px solid var(--border); position: relative; cursor: zoom-in;
}
.slide-thumb:hover { border-color: var(--teal-border); }
.slide-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
.slide-num {
  position: absolute; top: 6px; left: 8px;
  font-size: 0.5rem; color: rgba(240,232,220,0.6); letter-spacing: 0.1em;
  background: rgba(3,3,6,0.55); padding: 2px 5px; border-radius: 3px;
}
.reel-thumb {
  width: 100px; height: 178px; border-radius: 9px; overflow: hidden;
  border: 1px solid var(--border); cursor: zoom-in;
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  position: relative;
}
.reel-thumb:hover { border-color: rgba(192,160,240,0.4); }
.reel-thumb:hover .reel-zoom { opacity: 1; }
.reel-thumb video { width: 100%; height: 100%; object-fit: cover; }
.reel-zoom {
  position: absolute; inset: 0; background: rgba(3,3,6,0.35);
  display: flex; align-items: center; justify-content: center;
  opacity: 0; transition: opacity 0.15s; pointer-events: none;
  font-size: 1.2rem; color: rgba(240,232,220,0.8);
}
.publish-row { margin-top: 1.1rem; display: flex; flex-wrap: wrap; align-items: center; gap: 0.75rem; }
.btn-publish {
  padding: 8px 20px; border-radius: 30px; border: none; cursor: pointer;
  font-weight: 700; font-size: 0.68rem; letter-spacing: 0.07em; text-transform: uppercase;
  background: var(--red); color: #fff;
}
.btn-publish:disabled { opacity: 0.25; cursor: not-allowed; }
.schedule-input {
  background: rgba(255,255,255,0.05); border: 1px solid var(--border);
  border-radius: 7px; color: rgba(240,232,220,0.7); font-size: 0.68rem;
  padding: 5px 9px; outline: none; color-scheme: dark;
}
.btn-queue {
  padding: 8px 20px; border-radius: 30px; border: none; cursor: pointer;
  font-weight: 700; font-size: 0.68rem; letter-spacing: 0.07em; text-transform: uppercase;
  background: var(--teal); color: #030306;
  position: relative;
}
.btn-queue:disabled { opacity: 0.25; cursor: not-allowed; }
.btn-queue:hover:not(:disabled) { opacity: 0.88; }
.btn-retry {
  padding: 6px 16px; border-radius: 30px; border: 1px solid var(--amber); cursor: pointer;
  font-weight: 700; font-size: 0.65rem; letter-spacing: 0.07em; text-transform: uppercase;
  background: transparent; color: var(--amber);
}
.btn-retry:disabled { opacity: 0.3; cursor: not-allowed; }
.output-captions { margin-top: 1rem; }
.output-captions-title {
  font-size: 0.6rem; letter-spacing: 0.1em; text-transform: uppercase;
  color: var(--purple); margin-bottom: 0.5rem;
}
.cap-net-tabs { display: flex; gap: 0.25rem; margin-bottom: 0.5rem; }
.cap-net-tab {
  padding: 3px 10px; border-radius: 20px; cursor: pointer;
  font-size: 0.58rem; border: 1px solid var(--border); color: var(--dim); background: transparent;
}
.cap-net-tab.active { border-color: var(--purple); color: var(--purple); }
.cap-net-panel { display: none; }
.cap-net-panel.active { display: block; }
.cap-net-text {
  font-size: 0.78rem; line-height: 1.55; color: var(--text);
  background: rgba(255,255,255,0.025); border-radius: 7px;
  padding: 0.6rem 0.75rem; white-space: pre-wrap;
}
.error-block {
  border: 1px solid rgba(232,99,106,0.3); border-radius: 11px;
  padding: 1rem 1.1rem; background: rgba(232,99,106,0.04);
  margin-bottom: 0.875rem;
}
.error-slug { font-size: 0.58rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--red); margin-bottom: 0.25rem; }
.error-title { font-size: 0.95rem; font-weight: 600; margin-bottom: 0.5rem; }
.error-msg { font-size: 0.72rem; color: var(--muted); margin-bottom: 0.75rem; white-space: pre-wrap; font-family: monospace; }
.queue-date { font-size: 0.68rem; color: var(--muted); }

/* ── COPY PENDING (legacy) ── */
.avatar-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1rem; }
.avatar-card {
  border: 1px solid var(--border); border-radius: 11px;
  padding: 1.1rem; background: var(--surface);
}
.avatar-name { font-size: 0.6rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--teal); margin-bottom: 0.75rem; }
.variant-tabs { display: flex; gap: 0.25rem; margin-bottom: 0.75rem; }
.vtab {
  padding: 4px 10px; border-radius: 20px; cursor: pointer;
  font-size: 0.6rem; border: 1px solid var(--border); color: var(--dim); background: transparent;
}
.vtab.active { border-color: var(--teal-border); color: var(--teal); }
.variant-panel { display: none; }
.variant-panel.active { display: block; }
.slide-copy-row { display: flex; gap: 0.5rem; padding: 0.28rem 0; border-bottom: 1px solid rgba(255,255,255,0.04); align-items: baseline; }
.slide-copy-n   { font-size: 0.5rem; color: var(--dim); min-width: 1.5rem; }
.slide-copy-txt { font-size: 0.82rem; color: rgba(240,232,220,0.78); line-height: 1.4; }
.slide-copy-txt.hook { font-weight: 700; color: var(--text); }
.slide-copy-txt.cta  { color: var(--teal); font-size: 0.76rem; }
.dir-row   { margin-top: 0.75rem; border-top: 1px solid var(--border); padding-top: 0.75rem; }
.dir-label { font-size: 0.54rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--dim); margin-bottom: 0.45rem; }
.dir-opts  { display: flex; flex-wrap: wrap; gap: 0.3rem; }
.dir-btn {
  padding: 4px 10px; border-radius: 20px; font-size: 0.6rem; cursor: pointer;
  border: 1px solid var(--border); color: var(--dim); background: transparent;
}
.dir-btn.sel-c { border-color: var(--teal); color: var(--teal); }
.fmt-row { display: flex; gap: 0.4rem; margin-top: 0.75rem; }
.fmt-btn {
  flex: 1; padding: 8px 0; border-radius: 7px; cursor: pointer;
  font-size: 0.68rem; font-weight: 600; text-align: center;
  border: 1px solid var(--border); background: transparent; color: var(--dim);
}
.fmt-btn.on-carousel { border-color: var(--teal); color: var(--teal); background: var(--teal-bg); }
.fmt-btn.on-reel     { border-color: var(--purple); color: var(--purple); background: rgba(192,160,240,0.08); }
.article-approve {
  margin-top: 1.25rem; padding-top: 1rem; border-top: 1px solid var(--border);
  display: flex; align-items: center; gap: 0.75rem;
}
.btn-article-approve {
  padding: 8px 20px; border-radius: 30px; border: none; cursor: pointer;
  font-weight: 700; font-size: 0.68rem; letter-spacing: 0.07em; text-transform: uppercase;
  background: var(--teal); color: #020e0e;
}
.btn-article-approve:disabled { opacity: 0.22; cursor: not-allowed; }

/* ── STICKY FOOTER ── */
.footer-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: rgba(3,3,6,0.97); backdrop-filter: blur(16px);
  border-top: 1px solid var(--border); padding: 0.65rem 1.25rem;
  display: flex; align-items: center; gap: 1rem; z-index: 100;
}
.footer-count { flex: 1; font-size: 0.7rem; color: var(--muted); }
.footer-top   { font-size: 0.6rem; color: var(--dim); cursor: pointer; background: none; border: none; }
.footer-top:hover { color: var(--muted); }

#loading, #empty { color: var(--dim); font-size: 0.85rem; padding: 3rem 0; text-align: center; }

/* ── LIGHTBOX ── */
.lightbox {
  display: none; position: fixed; inset: 0;
  background: rgba(3,3,6,0.97); z-index: 200;
  align-items: center; justify-content: center; flex-direction: column; gap: 1rem;
}
.lightbox.open { display: flex; }
.lightbox img  { max-height: 84vh; max-width: 90vw; border-radius: 10px; }
.lightbox video { max-height: 84vh; max-width: 90vw; border-radius: 10px; outline: none; }
.lb-close {
  position: absolute; top: 1.25rem; right: 1.25rem;
  background: rgba(255,255,255,0.06); border: 1px solid var(--border);
  color: var(--muted); width: 34px; height: 34px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center; cursor: pointer; font-size: 0.85rem;
}
.lb-close:hover { color: var(--text); }
.lb-nav { display: flex; gap: 0.7rem; align-items: center; }
.lb-nav button {
  background: rgba(255,255,255,0.05); border: 1px solid var(--border);
  color: var(--muted); padding: 6px 16px; border-radius: 7px; cursor: pointer; font-size: 0.76rem;
}
.lb-nav button:hover { border-color: var(--teal-border); color: var(--teal); }
.lb-counter { font-size: 0.66rem; color: var(--dim); min-width: 4rem; text-align: center; }

@media (prefers-reduced-motion: reduce) { * { transition: none !important; } }
@media (max-width: 680px) {
  .finalist-grid { grid-template-columns: 1fr; }
  body { padding: 1rem 0.875rem 5rem; }
}
</style>
</head>
<body>

<div class="page-header">
  <h1 class="page-title">Review social</h1>
  <span class="page-badge" id="status-badge"></span>
</div>

<div id="loading">Cargando…</div>
<div id="empty" style="display:none">No hay artículos pendientes.</div>
<div id="content"></div>

<div class="footer-bar">
  <span class="footer-count" id="footer-count">Sin selecciones activas</span>
  <button class="footer-top" onclick="window.scrollTo({top:0,behavior:'smooth'})">↑ inicio</button>
</div>

<div class="lightbox" id="lightbox">
  <button class="lb-close" onclick="closeLb()">✕</button>
  <img id="lb-img" src="" alt="" style="display:none" />
  <video id="lb-video" src="" controls loop style="display:none"></video>
  <div class="lb-nav">
    <button onclick="lbStep(-1)">← Ant</button>
    <span class="lb-counter" id="lb-counter"></span>
    <button onclick="lbStep(1)">Sig →</button>
  </div>
</div>

<script is:inline>
// ── CONSTANTS ──────────────────────────────────────────────────────────────────

const AVATAR_LABELS = {
  negocio:    "Dueños de negocio",
  profesional:"Profesionales",
  padres:     "Padres",
  terapeuta:  "Terapeutas / coaches",
};

const DIRECTOR_LABELS = {
  loop:       "Loop — Malick",
  contrain:   "Contraintuición — Fincher",
  quote:      "Cita — Anderson",
  hook:       "Hook — WKW",
  pregunta:   "Pregunta — PTA",
  edu:        "Educativo — McKay",
  documental: "Documental — Herzog",
};

const DIRECTOR_SHORT = {
  loop: "Loop", contrain: "Contraintuición", quote: "Cita",
  hook: "Hook", pregunta: "Pregunta", edu: "Educativo", documental: "Documental",
};

const CAP_LIMITS = {
  instagram: 2200, tiktok: 2200, linkedin: 3000,
  youtube_title: 60, youtube_description: 500,
};

const DIM_LABELS = {
  hook_strength: "Hook", curiosity_gap: "Gap",
  emotional_trigger: "Emoción", avatar_fit: "Fit", shareability: "Share",
};

// ── STATE ──────────────────────────────────────────────────────────────────────

const cardStates = {};   // "slug:finalistId" → {approved, skipped, carousel, reel, director}

function stateKey(slug, fid) { return `${slug}:${fid}`; }

function getState(slug, fid) {
  const k = stateKey(slug, fid);
  if (!cardStates[k]) cardStates[k] = { approved: false, skipped: false, carousel: true, reel: false, director: 'loop' };
  return cardStates[k];
}

function updateCardVisual(card) {
  const state = cardStates[card.dataset.stateKey];
  if (!state) return;
  card.classList.toggle('state-approved', state.approved);
  card.classList.toggle('state-skipped', state.skipped);
  const btnA = card.querySelector('.btn-approve');
  const btnS = card.querySelector('.btn-skip');
  if (btnA) { btnA.textContent = state.approved ? '✓ Aprobado' : 'Aprobar'; btnA.classList.toggle('approved', state.approved); }
  if (btnS) btnS.classList.toggle('skipped', state.skipped);
}

function approveCard(card) {
  const { slug, finalistId } = card.dataset;
  const state = getState(slug, finalistId);
  state.approved = !state.approved;
  if (state.approved) state.skipped = false;
  updateCardVisual(card);
  updateArticleFooter(slug);
}

function skipCard(card) {
  const { slug, finalistId } = card.dataset;
  const state = getState(slug, finalistId);
  state.skipped = !state.skipped;
  if (state.skipped) state.approved = false;
  updateCardVisual(card);
  updateArticleFooter(slug);
}

function updateArticleFooter(slug) {
  const approvedKeys = Object.entries(cardStates).filter(([k, s]) => k.startsWith(slug + ':') && s.approved);
  const count = approvedKeys.length;
  const btn = document.getElementById(`submit-btn-${slug}`);
  const msg = document.getElementById(`submit-msg-${slug}`);
  if (btn) btn.disabled = count === 0;
  if (msg) msg.textContent = count ? `${count} finalista${count > 1 ? 's' : ''} marcado${count > 1 ? 's' : ''}` : '';
  const total = Object.values(cardStates).filter(s => s.approved).length;
  const el = document.getElementById('footer-count');
  if (el) el.textContent = total ? `${total} selección${total !== 1 ? 'es' : ''} activa${total !== 1 ? 's' : ''}` : 'Sin selecciones activas';
}

// ── HELPERS ────────────────────────────────────────────────────────────────────

function esc(s) {
  return (s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

function scoreClass(n) { return n >= 75 ? 'sc-high' : n >= 55 ? 'sc-mid' : 'sc-low'; }

function getFinalistCaptions(slug, fid) {
  const nets = ['instagram','tiktok','linkedin','youtube_title','youtube_description'];
  const out = {};
  const prefix = `ta-${slug}-${fid}`;
  for (const n of nets) {
    const ta = document.getElementById(`${prefix}-${n}`);
    if (ta && ta.value.trim()) out[n] = ta.value;
  }
  return Object.keys(out).length ? out : null;
}

function updateCharCount(fid, field, limit) {
  const ta = document.getElementById(`ta-${fid}-${field}`);
  const cc = document.getElementById(`cc-${fid}-${field}`);
  if (!ta || !cc) return;
  const len = ta.value.length;
  cc.textContent = `${len}/${limit}`;
  cc.classList.toggle('over', len > limit);
}

// ── SCORED BLOCK ───────────────────────────────────────────────────────────────

function buildScoredBlock(item) {
  const block = document.createElement('div');
  block.className = 'article-block';
  block.id = `article-${item.slug}`;
  block.innerHTML = `
    <div class="article-title">${esc(item.title || item.slug)}</div>
    <div class="article-slug">${esc(item.slug)}</div>
  `;

  const grid = document.createElement('div');
  grid.className = 'finalist-grid';

  for (const fid of item.finalists) {
    const m = fid.match(/^(.+)_v(\d+)$/);
    if (!m) continue;
    const [, avatar, vStr] = m;
    const vIdx = parseInt(vStr, 10);
    const scoreData = item.viral_scores?.[fid] || {};
    const variant   = item.avatar_variants?.[avatar]?.[vIdx] || {};
    const captions  = item.captions?.[fid] || {};
    grid.appendChild(buildFinalistCard(item.slug, fid, avatar, vIdx, scoreData, variant, captions));
  }

  block.appendChild(grid);

  const footer = document.createElement('div');
  footer.className = 'article-ft';
  footer.innerHTML = `
    <button class="btn-submit" id="submit-btn-${esc(item.slug)}" disabled>
      Enviar aprobados
    </button>
    <span class="submit-msg" id="submit-msg-${esc(item.slug)}"></span>
  `;
  footer.querySelector('.btn-submit').addEventListener('click', () => submitApproved(item.slug, item.finalists));
  block.appendChild(footer);
  return block;
}

function buildFinalistCard(slug, fid, avatar, vIdx, scoreData, variant, captions) {
  const card = document.createElement('div');
  card.className = 'finalist-card';
  card.dataset.slug       = slug;
  card.dataset.finalistId = fid;
  card.dataset.stateKey   = stateKey(slug, fid);

  const score  = scoreData.score || 0;
  const dims   = scoreData.dimensions || {};
  const sugDir = scoreData.suggested_director || 'loop';
  const justif = scoreData.justification || '';

  const slides = variant.carousel?.slides || [];
  const reel   = variant.reel || {};

  // Init state
  const state  = getState(slug, fid);
  state.director = sugDir;

  // Dim bars
  const dimBars = Object.entries(DIM_LABELS).map(([key, lbl]) => {
    const v = dims[key] || 0;
    return `<div class="dim-item">
      <span class="dim-lbl">${lbl}</span>
      <div class="dim-track"><div class="dim-fill" style="width:${v}%"></div></div>
      <span class="dim-val">${v}</span>
    </div>`;
  }).join('');

  // All slides
  const slidesHtml = slides.map((s, i) => {
    const isHook = i === 0;
    const isCta  = i === slides.length - 1;
    const cls    = isHook ? 'is-hook' : isCta ? 'is-cta' : '';
    return `<div class="slide-row">
      <span class="slide-n">${String(i+1).padStart(2,'0')}</span>
      <span class="slide-txt ${cls}">${esc(s)}</span>
    </div>`;
  }).join('');

  // Reel hooks
  const reelHtml = reel.hook_a ? `<div class="reel-section">
    <div class="reel-row"><span class="reel-lbl">A</span><span class="reel-txt">${esc(reel.hook_a)}</span></div>
    ${reel.hook_b ? `<div class="reel-row"><span class="reel-lbl">B</span><span class="reel-txt">${esc(reel.hook_b)}</span></div>` : ''}
    ${reel.cta ? `<div class="reel-row"><span class="reel-lbl">→</span><span class="reel-txt" style="color:var(--teal)">${esc(reel.cta)}</span></div>` : ''}
  </div>` : '';

  // Director options
  const dirOpts = Object.entries(DIRECTOR_SHORT)
    .map(([k, v]) => `<option value="${k}"${k === sugDir ? ' selected' : ''}>${v}</option>`)
    .join('');

  // Caption tabs (empty textareas — values set via .value after innerHTML)
  const capTabsHtml = ['instagram','tiktok','linkedin','youtube'].map((net, i) =>
    `<button class="cap-tab${i===0?' active':''}" data-net="${net}">${net === 'youtube' ? 'YT' : net.charAt(0).toUpperCase() + net.slice(1)}</button>`
  ).join('');

  const sfid = `${slug}-${fid}`;
  const capPanelsHtml = ['instagram','tiktok','linkedin'].map((net, i) => {
    const lim = CAP_LIMITS[net];
    return `<div class="cap-panel${i===0?' active':''}" id="cap-${sfid}-${net}">
      <textarea class="cap-textarea" id="ta-${sfid}-${net}" rows="5"
        oninput="updateCharCount('${sfid}','${net}',${lim})"></textarea>
      <div class="cap-char" id="cc-${sfid}-${net}">0/${lim}</div>
    </div>`;
  }).join('') + `<div class="cap-panel" id="cap-${sfid}-youtube">
    <div class="cap-yt-fields">
      <div>
        <div class="cap-yt-lbl">Título</div>
        <textarea class="cap-textarea" id="ta-${sfid}-youtube_title" rows="2"
          oninput="updateCharCount('${sfid}','youtube_title',${CAP_LIMITS.youtube_title})"></textarea>
        <div class="cap-char" id="cc-${sfid}-youtube_title">0/${CAP_LIMITS.youtube_title}</div>
      </div>
      <div>
        <div class="cap-yt-lbl">Descripción</div>
        <textarea class="cap-textarea" id="ta-${sfid}-youtube_description" rows="3"
          oninput="updateCharCount('${sfid}','youtube_description',${CAP_LIMITS.youtube_description})"></textarea>
        <div class="cap-char" id="cc-${sfid}-youtube_description">0/${CAP_LIMITS.youtube_description}</div>
      </div>
    </div>
  </div>`;

  card.innerHTML = `
    <div class="card-hd">
      <span class="card-label">${esc(AVATAR_LABELS[avatar] || avatar)} v${vIdx+1}</span>
      <span class="card-score ${scoreClass(score)}">${score}</span>
      <select class="card-dir-select">
        ${dirOpts}
      </select>
    </div>
    <div class="dim-row">${dimBars}</div>
    ${slides.length ? `<div class="slides-section">${slidesHtml}</div>` : ''}
    ${reelHtml}
    ${justif ? `<div class="card-justif">"${esc(justif)}"</div>` : ''}
    <div class="cap-tab-row">${capTabsHtml}</div>
    <div class="cap-panels">${capPanelsHtml}</div>
    <div class="card-ft">
      <label class="fmt-toggle">
        <input type="checkbox" id="fmt-car-${sfid}" checked> Carrusel
      </label>
      <label class="fmt-toggle">
        <input type="checkbox" id="fmt-reel-${sfid}"> Reel
      </label>
      <span class="ft-divider"></span>
      <button class="btn-skip">Skip</button>
      <button class="btn-approve">Aprobar</button>
    </div>
  `;

  // Set caption values AFTER innerHTML (avoids HTML injection)
  const captionMap = {
    instagram:           captions.instagram || '',
    tiktok:              captions.tiktok || '',
    linkedin:            captions.linkedin || '',
    youtube_title:       captions.youtube_title || '',
    youtube_description: captions.youtube_description || '',
  };
  for (const [field, val] of Object.entries(captionMap)) {
    const ta = card.querySelector(`#ta-${sfid}-${field}`);
    const cc = card.querySelector(`#cc-${sfid}-${field}`);
    const lim = CAP_LIMITS[field];
    if (ta) ta.value = val;
    if (cc && lim) cc.textContent = `${val.length}/${lim}`;
  }

  // Caption tab switching — event listeners (no global onclick)
  const tabRow = card.querySelector('.cap-tab-row');
  tabRow.addEventListener('click', e => {
    const tab = e.target.closest('.cap-tab');
    if (!tab) return;
    const net = tab.dataset.net;
    tabRow.querySelectorAll('.cap-tab').forEach(t => t.classList.remove('active'));
    tab.classList.add('active');
    card.querySelectorAll('.cap-panel').forEach(p => p.classList.remove('active'));
    const panel = card.querySelector(`#cap-${sfid}-${net}`);
    if (panel) panel.classList.add('active');
  });

  // Director change
  const dirSelect = card.querySelector('.card-dir-select');
  dirSelect.addEventListener('change', () => { getState(slug, fid).director = dirSelect.value; });

  // Format checkboxes
  card.querySelector(`#fmt-car-${sfid}`).addEventListener('change', e => { getState(slug, fid).carousel = e.target.checked; });
  card.querySelector(`#fmt-reel-${sfid}`).addEventListener('change', e => { getState(slug, fid).reel = e.target.checked; });

  // Approve / Skip
  card.querySelector('.btn-approve').addEventListener('click', () => approveCard(card));
  card.querySelector('.btn-skip').addEventListener('click', () => skipCard(card));

  return card;
}

// ── SUBMIT APPROVED ────────────────────────────────────────────────────────────

async function submitApproved(slug, finalists) {
  const btn = document.getElementById(`submit-btn-${slug}`);
  const msg = document.getElementById(`submit-msg-${slug}`);

  const approved_selections = finalists
    .filter(fid => cardStates[stateKey(slug, fid)]?.approved)
    .map(fid => {
      const state = cardStates[stateKey(slug, fid)] || {};
      const m = fid.match(/^(.+)_v(\d+)$/);
      const [, avatar, vStr] = m;
      return {
        finalist_id:     fid,
        avatar,
        variant_index:   parseInt(vStr, 10),
        director:        state.director || 'loop',
        carousel:        state.carousel !== false,
        reel:            !!state.reel,
        edited_captions: getFinalistCaptions(slug, fid),
      };
    });

  if (!approved_selections.length) return;

  btn.disabled = true;
  btn.textContent = 'Enviando…';

  try {
    const res  = await fetch('/api/approve-copy', {
      method: 'POST', credentials: 'same-origin',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ slug, approved_selections }),
    });
    const data = await res.json();
    if (data.ok) {
      btn.textContent = `✓ ${data.approved} en cola`;
      if (msg) msg.textContent = 'Oracle genera en ~30 min.';
    } else {
      btn.disabled = false; btn.textContent = 'Enviar aprobados';
      if (msg) msg.textContent = `Error: ${data.error}`;
    }
  } catch (e) {
    btn.disabled = false; btn.textContent = 'Enviar aprobados';
    if (msg) msg.textContent = `Error: ${e.message}`;
  }
}

// ── OUTPUT BLOCK (ready_to_publish) ───────────────────────────────────────────

let _nextQueueSlot = 0; // advances with each "añadir a la cola" click this session

function nextPublishDate(offset = 0) {
  const d = new Date();
  d.setDate(d.getDate() + _nextQueueSlot + offset + 1);
  return d.toLocaleDateString('es-CL', { weekday: 'long', day: 'numeric', month: 'long' });
}

function _refreshQueueDates() {
  let i = 0;
  document.querySelectorAll('.btn-queue:not(:disabled)').forEach(btn => {
    const date = nextPublishDate(i++);
    btn.title = `Próxima publicación disponible: ${date} a las 11:11 (Chile)`;
    const span = btn.parentElement?.querySelector('.queue-date');
    if (span) span.textContent = `${date}, 11:11 Chile`;
  });
}

function buildCaptionTabs(captions, slug, fid) {
  const networks = [
    { k: 'instagram',          label: 'IG' },
    { k: 'tiktok',             label: 'TT' },
    { k: 'linkedin',           label: 'LI' },
    { k: 'youtube_title',      label: 'YT título' },
    { k: 'youtube_description',label: 'YT desc' },
  ];
  const available = networks.filter(n => captions[n.k]);
  if (!available.length) return '';
  const uid = `${slug}-${fid}`;
  const tabs = available.map((n, i) =>
    `<button class="cap-net-tab${i===0?' active':''}" onclick="switchCapTab(this,'${uid}')"
      data-net="${n.k}">${n.label}</button>`
  ).join('');
  const panels = available.map((n, i) =>
    `<div class="cap-net-panel${i===0?' active':''}" id="cnp-${uid}-${n.k}">
      <div class="cap-net-text">${esc(captions[n.k])}</div>
    </div>`
  ).join('');
  return `<div class="cap-net-tabs">${tabs}</div>${panels}`;
}

function switchCapTab(btn, uid) {
  const parent = btn.closest('.output-captions');
  parent.querySelectorAll('.cap-net-tab').forEach(t => t.classList.remove('active'));
  parent.querySelectorAll('.cap-net-panel').forEach(p => p.classList.remove('active'));
  btn.classList.add('active');
  const panel = parent.querySelector(`#cnp-${uid}-${btn.dataset.net}`);
  if (panel) panel.classList.add('active');
}

function buildOutputBlock(item) {
  const block = document.createElement('div');
  block.className = 'article-block';

  const carUrls  = item.r2_urls.filter(u => u.includes('/carrusel/'));
  const reelUrls = item.r2_urls.filter(u => u.includes('/reels/'));

  const pubDate  = nextPublishDate(0);
  const tooltip  = `Próxima publicación disponible: ${pubDate} a las 11:11 (Chile)`;

  let h = `
    <div class="article-title">${esc(item.title || item.slug)}</div>
    <div class="article-slug">${esc(item.slug)}</div>`;

  if (carUrls.length) {
    h += `<div class="media-subsection">
      <div class="media-subsection-h">Carrusel — ${carUrls.length} slides · click para zoom · ← →</div>
      <div class="carousel-strip">`;
    carUrls.forEach((url, i) => {
      h += `<div class="slide-thumb" onclick="openLb(${JSON.stringify(carUrls)},${i})">
        <span class="slide-num">${String(i+1).padStart(2,'0')}</span>
        <img src="${url}" loading="lazy" alt="slide ${i+1}" />
      </div>`;
    });
    h += `</div></div>`;
  }

  if (reelUrls.length) {
    h += `<div class="media-subsection">
      <div class="media-subsection-h">Reels — ${reelUrls.length} · click para ver</div>
      <div style="display:flex;gap:0.75rem;flex-wrap:wrap;margin-bottom:0.5rem">`;
    reelUrls.forEach(url => {
      h += `<div class="reel-thumb" onclick="openReel('${url}')">
        <video src="${url}" loop muted playsinline
          onmouseenter="this.play()" onmouseleave="this.pause();this.currentTime=0"></video>
        <div class="reel-zoom">▶</div>
      </div>`;
    });
    h += `</div></div>`;
  }

  // Captions por finalista aprobado
  if (item.approved?.length && Object.keys(item.captions || {}).length) {
    item.approved.forEach((appr, ai) => {
      const fid      = appr.finalist_id || `${appr.avatar}_v${appr.variant_index ?? 0}`;
      const caps     = item.captions[fid] || {};
      const hasCaps  = Object.values(caps).some(Boolean);
      if (!hasCaps) return;
      h += `<div class="output-captions">
        <div class="output-captions-title">${esc(fid)} — copy aprobado</div>
        ${buildCaptionTabs(caps, esc(item.slug), esc(fid))}
      </div>`;
    });
  }

  h += `<div class="publish-row">
    <button class="btn-queue" title="${esc(tooltip)}"
      onclick="approveVisual('${esc(item.slug)}',this)">Añadir a la cola</button>
    <span class="queue-date">${esc(pubDate)}, 11:11 Chile</span>
  </div>`;

  block.innerHTML = h;
  return block;
}

// ── ERROR BLOCK (generation_error) ─────────────────────────────────────────────

function buildErrorBlock(item) {
  const block = document.createElement('div');
  block.className = 'error-block';
  block.innerHTML = `
    <div class="error-slug">${esc(item.slug)}</div>
    <div class="error-title">${esc(item.title || item.slug)}</div>
    <div class="error-msg">${esc((item.last_error || '').slice(0, 400))}</div>
    <button class="btn-retry" id="retry-${esc(item.slug)}"
      onclick="retryGeneration('${esc(item.slug)}',this)">Reintentar generación</button>
  `;
  return block;
}

// ── COPY BLOCK (legacy copy_pending_review) ───────────────────────────────────

function buildCopyBlock(item) {
  const block = document.createElement('div');
  block.className = 'article-block';
  block.id = `article-${item.slug}`;
  block.innerHTML = `
    <div class="article-title">${esc(item.title || item.slug)}</div>
    <div class="article-slug">${esc(item.slug)}</div>
  `;

  const grid = document.createElement('div');
  grid.className = 'avatar-grid';
  for (const [avatarName, variants] of Object.entries(item.avatar_variants || {})) {
    grid.appendChild(buildAvatarCard(item.slug, avatarName, variants));
  }
  block.appendChild(grid);

  const approveRow = document.createElement('div');
  approveRow.className = 'article-approve';
  approveRow.innerHTML = `
    <button class="btn-article-approve" id="approve-btn-${esc(item.slug)}" disabled
      onclick="approveLegacy('${esc(item.slug)}')">Aprobar este artículo</button>
    <span class="submit-msg" id="approve-msg-${esc(item.slug)}"></span>
  `;
  block.appendChild(approveRow);
  return block;
